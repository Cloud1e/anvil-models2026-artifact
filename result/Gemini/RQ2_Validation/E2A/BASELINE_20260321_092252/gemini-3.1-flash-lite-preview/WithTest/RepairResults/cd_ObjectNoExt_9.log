module unknown
open util/integer [] as integer
sig Class {
ext: (lone Class)
}
one sig Object extends Class {}
pred ObjectNoExt[] {
(Object !in (Class.ext))
}
pred Acyclic[] {
(all c: (one Class) {
(c !in (c.(^ext)))
})
}
pred AllExtObject[] {
(all c: (one (Class - Object)) {
(c in (Object.(^(~ext))))
})
}
pred ClassHierarchy[] {
((ObjectNoExt[]) && (Acyclic[]) && (AllExtObject[]))
}



