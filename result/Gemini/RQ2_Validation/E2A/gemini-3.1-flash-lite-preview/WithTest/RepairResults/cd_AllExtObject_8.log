(all c: (one Class) {
(c !in (c.(^ext)))
})
}
pred AllExtObject[] {
((Object.(^(~(ext - iden)))) = (Class - Object))
}
pred ClassHierarchy[] {
((ObjectNoExt[]) && (Acyclic[]) && (AllExtObject[]))
}



run ClassHierarchy for 3

