elem: (one Int)
}
pred UniqueElem[] {
(no disj n1,n2: (one Node) {
((n1.elem) = (n2.elem))
})
}
pred Sorted[] {
(all n: (one Node) {
((some (n.nxt)) => ((n.elem) <= ((n.nxt).elem)))
})
}
pred ConsistentPreAndNxt[] {
(all n1,n2: (one Node) {
(((n1.nxt) != n2) => ((((n2.pre) = n1) && ((n2.pre) = n1)) => ((n1.nxt) = n2)))
})
}
pred RepOk[] {
((UniqueElem[]) && (Sorted[]) && (ConsistentPreAndNxt[]))
}

fact Reachable {
(Node = ((DLL.header).(*nxt)))
}
pred Acyclic[] {
(all n: (one Node) {
(n !in (n.(^nxt)))
})
}



pred AcyclicMUTATED[] {
(all n: (one Node) {
(n !in (n.(^(~nxt))))
})
}
EQUIV: check { Acyclic[] <=> AcyclicMUTATED[] } for 3
