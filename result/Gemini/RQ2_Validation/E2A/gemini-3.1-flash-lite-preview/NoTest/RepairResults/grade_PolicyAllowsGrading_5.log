associated_with: (one Class),
assigned_to: (some Student)
}
pred PolicyAllowsGrading[s: Person,a: Assignment] {
((s in ((a.associated_with).(assistant_for+instructor_of))) && (!(some x: (one (a.assigned_to)) {
(x = s)
