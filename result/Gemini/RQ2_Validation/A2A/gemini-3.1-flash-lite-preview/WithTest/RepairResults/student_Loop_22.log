}
sig Node {
link: (set Node),
elem: (set Int)
}
abstract sig Boolean {}
one sig True extends Boolean {}
one sig False extends Boolean {}
pred Loop[This: List] {
((no (This.header)) || (all n: (one ((This.header).(*link))) {
(((n.link) = n) => (none != n))
}))
}
pred Sorted[This: List] {
(all n: (one ((This.header).(*link))) {
((no (n.link)) || ((n.elem) <= ((n.link).elem)))
})
}
pred RepOk[This: List] {
((Loop[This]) && (Sorted[This]))
}
pred Count[This: List,x: Int,result: Int] {
((RepOk[This]) && (result = (#({ n: (one ((This.header).(*link))) {
((n.elem) = x)
} }))))
}
pred Contains[This: List,x: Int,result: Boolean] {
((RepOk[This]) && ((some n: (one ((This.header).(*link))) {
((n.elem) = x)
}) => (result = True) else (result = False)))
}

fact CardinalityConstraints {
((all l: (one List) {
(lone (l.header))
}) && (all n: (one Node) {
(lone (n.link))
}) && (all n: (one Node) {
(one (n.elem))
}))
}
fact IGNORE {
((one List) && (((List.header).(*link)) = Node))
}



pred ContainsMUTATED[This: List,x: Int,result: Boolean] {
((RepOk[This]) && ((some n: (one ((This.header).(*(^link)))) {
((n.elem) = x)
}) => (result = True) else (result = False)))
}
EQUIV: check { all This: List,x: Int,result: Boolean | Contains[This,x,result] <=> ContainsMUTATED[This,x,result] } for 3
