 [INFO] Original model:
module unknown
open util/integer [] as integer
sig Room {}
one sig secure_lab extends Room {}
abstract sig Person {
owns: (set Key)
}
sig Employee extends Person {}
sig Researcher extends Person {}
sig Key {
authorized: (one Employee),
opened_by: (one Room)
}
pred CanEnter[p: Person,r: Room] {
(some k: (one Key) {
(((p->k) in owns) && ((k->r) in opened_by))
})
}

fact fact_1 {
(no (Employee.owns))
}
assert no_thief_in_seclab {
(all p: (one Person) {
((CanEnter[p,secure_lab]) => (p in Researcher))
})
}

check no_thief_in_seclab

