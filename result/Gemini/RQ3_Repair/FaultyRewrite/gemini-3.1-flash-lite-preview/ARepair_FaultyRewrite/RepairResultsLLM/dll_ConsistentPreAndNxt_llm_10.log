 [INFO] Original model:
module unknown
open util/integer [] as integer
one sig DLL {
header: (lone Node)
}
sig Node {
pre,nxt: (lone Node),
elem: (one Int)
}
pred UniqueElem[] {
(no disj n1,n2: (one Node) {
((n1.elem) = (n2.elem))
})
}
pred Sorted[] {
(all n: (one Node) {
((some (n.nxt)) => ((n.elem) <= ((n.nxt).elem)))
})
}
pred ConsistentPreAndNxt[] {
(all n,m: (one Node) {
(((n.nxt) = m) <=> ((m.pre) = n))
})
}
pred RepOk[] {
((UniqueElem[]) && (Sorted[]) && (ConsistentPreAndNxt[]))
}

fact Reachable {
(Node = ((DLL.header).(*nxt)))
}
fact Acyclic {
(all n: (one Node) {
(n !in (n.(^nxt)))
})
}

run RepOk for 3

