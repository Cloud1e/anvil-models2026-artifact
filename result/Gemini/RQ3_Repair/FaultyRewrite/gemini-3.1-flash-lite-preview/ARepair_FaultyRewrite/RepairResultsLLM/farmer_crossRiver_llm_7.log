 [INFO] Original model:
module farmer
open util/integer [] as integer
open util/ordering [State] as ord
abstract sig Object {
eats: (set Object)
}
one sig Farmer extends Object {}
one sig Fox extends Object {}
one sig Chicken extends Object {}
one sig Grain extends Object {}
sig State {
near: (set Object),
far: (set Object)
}
pred crossRiver[from,from',to,to': (set Object)] {
(!(((from' != (from - Farmer)) || (to' != ((to - (to.eats)) + Farmer))) && (all item: (one (from - Farmer)) {
((from' != ((from - Farmer) - item)) || (to' != (((to - (to.eats)) + Farmer) + item)))
})))
}
pred solvePuzzle[] {
(((ord/last[]).far) = Object)
}

fact eating {
(eats = ((Fox->Chicken) + (Chicken->Grain)))
}
fact initialState {
(let s0 = (ord/first[]) {
(((s0.near) = Object) && (no (s0.far)))
})
}
fact stateTransition {
(all s: (one State),s': (one (s.(ord/next[]))) {
((Farmer in (s.near)) => (crossRiver[(s.near),(s'.near),(s.far),(s'.far)]) else (crossRiver[(s.far),(s'.far),(s.near),(s'.near)]))
})
}
assert NoQuantumObjects {
(no s: (one State) {
(some x: (one Object) {
((x in (s.near)) && (x in (s.far)))
})
})
}
run solvePuzzle for 8 State expect 1
check NoQuantumObjects for 8 State expect 0

