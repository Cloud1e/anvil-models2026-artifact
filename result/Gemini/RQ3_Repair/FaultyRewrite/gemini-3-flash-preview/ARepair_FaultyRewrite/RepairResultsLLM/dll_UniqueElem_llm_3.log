 [INFO] Original model:
module unknown
open util/integer [] as integer
one sig DLL {
header: (lone Node)
}
sig Node {
pre,nxt: (lone Node),
elem: (one Int)
}
pred UniqueElem[] {
(all n: (one Node) {
(((n.pre).elem)disjoint ((n.nxt).elem))
})
}
pred Sorted[] {
(all n: (one Node) {
((some (n.nxt)) => ((n.elem) <= ((n.nxt).elem)))
})
}
pred ConsistentPreAndNxt[] {
(nxt = (~pre))
}
pred RepOk[] {
((UniqueElem[]) && (Sorted[]) && (ConsistentPreAndNxt[]))
}

fact Reachable {
(Node = ((DLL.header).(*nxt)))
}
fact Acyclic {
(all n: (one Node) {
(n !in (n.(^nxt)))
})
}

run RepOk for 3

