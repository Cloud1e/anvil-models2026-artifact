fun Depth[n: Node] : (one Int) {
(#(n.(*(~(left + right)))))
}
fact Reachable {
(Node = ((BinaryTree.root).(*(left + right))))
}
fact Acyclic {
(all n: (one Node) {
((n !in (n.(^(left + right)))) && (lone (n.(~(left + right)))) && (no ((n.left) & (n.right))))
})
}

