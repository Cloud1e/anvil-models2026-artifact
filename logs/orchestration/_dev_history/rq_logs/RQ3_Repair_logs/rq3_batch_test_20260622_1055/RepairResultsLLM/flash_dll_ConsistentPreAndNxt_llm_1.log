((some (n.nxt)) => ((n.elem) <= ((n.nxt).elem)))
})
}
pred ConsistentPreAndNxt[] {
(all disj n1,n2: (one Node) {
(((n1.nxt) = n2) <=> ((n2.pre) = n1))
})
}
pred RepOk[] {
((UniqueElem[]) && (Sorted[]) && (ConsistentPreAndNxt[]))
}

fact Reachable {
(Node = ((DLL.header).(*nxt)))
}
fact Acyclic {
(all n: (one Node) {
(n !in (n.(^(pre+(~nxt)))))
})
}

run RepOk for 3

