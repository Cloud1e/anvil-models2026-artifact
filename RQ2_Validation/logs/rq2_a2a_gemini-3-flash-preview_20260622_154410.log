root: (lone Node)
}
sig Node {
left,right: (lone Node),
elem: (one Int)
}
pred Sorted[] {
(all n: (one Node) {
((all nl: (one ((n.left).(*(left + right)))) {
((nl.elem) < (n.elem))
}) && (all nr: (one ((n.right).(*(left + right)))) {
((nr.elem) > (n.elem))
}))
})
}
pred HasAtMostOneChild[n: Node] {
((no (n.left)) || (no (n.right)))
}
pred Balanced[] {
(no n1,n2: (one Node) {
((HasAtMostOneChild[n1]) && (HasAtMostOneChild[n2]) && ((((Depth[n1]) - (Depth[n2])) > 1) || (((Depth[n2]) - (Depth[n1])) > 1)))
})
}
pred RepOk[] {
((Sorted[]) && (Balanced[]))
}
fun Depth[n: Node] : (one Int) {
(#(n.(*(~(left + right)))))
}
fact Reachable {
(Node = ((BinaryTree.root).(*(left + right))))
}
fact Acyclic {
(all n: (one Node) {
((n !in (n.(^(left + right)))) && (lone (n.(~(left + right)))) && (no ((n.left) & (n.right))))
})
}

run RepOk for 5

fun DepthMUTATED[n: Node] : (one Int) {
(#(n.(*(~((*left) + right)))))
}
