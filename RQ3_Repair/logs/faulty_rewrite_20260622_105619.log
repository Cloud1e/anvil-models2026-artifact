ext: (lone Class)
}
one sig Object extends Class {}
pred ObjectNoExt[] {
(no (Object.ext))
}
pred Acyclic[] {
(all c: (one Class) {
(c !in (c.(^ext)))
})
}
pred AllExtObject[] {
(all c: (one Class) {
((c in (Class - Object)) => (c in (c.(*ext))))
})
}
pred ClassHierarchy[] {
((ObjectNoExt[]) && (Acyclic[]) && (AllExtObject[]))
}



